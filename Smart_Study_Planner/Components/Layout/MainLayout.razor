@inherits LayoutComponentBase
@using SmartStudyPlanner.Services
@inject AuthService Auth
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn)
{
    @Body
}
else
{
    <div class="app-wrapper @(Auth.CurrentUser!.DarkTheme ? "dark-theme" : "")">
        <!-- Sidebar -->
        <nav class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-logo">
                    <span class="logo-icon">A</span>
                </div>
                <div class="brand-text">
                    <span class="brand-title">Smart Study</span>
                    <span class="brand-sub">Planner</span>
                </div>
            </div>

            <ul class="sidebar-nav">
                <li>
                    <NavLink href="/dashboard" class="nav-link" ActiveClass="active">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/schedule" class="nav-link" ActiveClass="active">
                        <i class="bi bi-calendar3"></i>
                        <span>Schedule</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/tasks" class="nav-link" ActiveClass="active">
                        <i class="bi bi-check2-square"></i>
                        <span>Tasks</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/pomodoro" class="nav-link" ActiveClass="active">
                        <i class="bi bi-stopwatch-fill"></i>
                        <span>Pomodoro</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/analytics" class="nav-link" ActiveClass="active">
                        <i class="bi bi-bar-chart-line-fill"></i>
                        <span>Analytics</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink href="/settings" class="nav-link" ActiveClass="active">
                        <i class="bi bi-gear-fill"></i>
                        <span>Settings</span>
                    </NavLink>
                </li>
            </ul>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <header class="top-header">
                <div class="header-left">
                    <h4 class="page-title">@GetPageTitle()</h4>
                </div>
                <div class="header-right">
                    <button class="header-icon-btn">
                        <i class="bi bi-bell-fill"></i>
                    </button>
                    <div class="user-avatar">
                        <span>@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</span>
                    </div>
                </div>
            </header>

            <div class="page-body">
                @Body
            </div>
        </div>
    </div>
}

@code {
    string GetPageTitle()
    {
        var path = Nav.Uri.ToLower();
        if (path.Contains("dashboard")) return "Dashboard";
        if (path.Contains("schedule")) return "Smart Study Scheduler";
        if (path.Contains("tasks")) return "My Tasks";
        if (path.Contains("pomodoro")) return "Smart Study Pomodoro";
        if (path.Contains("analytics")) return "Academic Analytics & Reports";
        if (path.Contains("settings")) return "Settings & Configuration";
        return "Smart Study Planner";
    }
}
