@page "/notes"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="notes-layout">
    <!-- Left: Add Note Form -->
    <div class="dash-card notes-input-card">
        <h6 class="card-heading">@(editNoteId > 0 ? "Edit Note" : "Add New Note")</h6>

        <div class="mb-2">
            <label class="ssp-label">Title</label>
            <input @bind="noteTitle" class="form-control ssp-input" placeholder="Note title..." />
        </div>
        <div class="mb-2">
            <label class="ssp-label">Subject</label>
            <select @bind="noteSubject" class="form-select ssp-input">
                <option value="">-- General --</option>
                @foreach (var s in subjects)
                {
                    <option value="@s.Name">@s.Name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="ssp-label">Content</label>
            <textarea @bind="noteContent" class="form-control ssp-input" rows="6" placeholder="Write your notes here..."></textarea>
        </div>

        @if (!string.IsNullOrEmpty(noteMsg))
        {
            <div class="alert alert-info py-1 small mb-2">@noteMsg</div>
        }

        <button class="btn btn-login w-100 mb-2" @onclick="SaveNote">
            <i class="bi @(editNoteId > 0 ? "bi-check-lg" : "bi-plus-lg") me-2"></i>
            @(editNoteId > 0 ? "Update Note" : "Save Note")
        </button>

        @if (editNoteId > 0)
        {
            <button class="btn btn-register w-100" @onclick="CancelEdit">Cancel</button>
        }
    </div>

    <!-- Right: Notes List -->
    <div>
        <div class="notes-filter-row mb-3">
            <button class="filter-btn @(filterSubj == "" ? "active" : "")" @onclick='() => filterSubj = ""'>All</button>
            @foreach (var s in subjects)
            {
                <button class="filter-btn @(filterSubj == s.Name ? "active" : "")" @onclick="() => filterSubj = s.Name">@s.Name</button>
            }
        </div>

        @if (!FilteredNotes.Any())
        {
            <div class="dash-card text-center py-4 text-muted">No notes yet. Add your first note!</div>
        }
        @foreach (var note in FilteredNotes)
        {
            <div class="dash-card note-card mb-3">
                <div class="note-card-header">
                    <div>
                        <h6 class="note-title">@note.Title</h6>
                        <small class="text-muted">
                            @if (!string.IsNullOrEmpty(note.SubjectName))
                            {
                                <span class="subject-tag me-2">@note.SubjectName</span>
                            }
                            @note.CreatedAt.ToString("MMM dd, yyyy")
                        </small>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="action-btn text-primary" @onclick="() => EditNote(note)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="action-btn text-danger" @onclick="() => DeleteNote(note)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <p class="note-content">@note.Content</p>
            </div>
        }
    </div>
</div>

@code {
    List<Note> notes = new();
    List<Subject> subjects = new();
    string noteTitle = "", noteContent = "", noteSubject = "", noteMsg = "";
    int editNoteId = 0;
    string filterSubj = "";

    IEnumerable<Note> FilteredNotes => string.IsNullOrEmpty(filterSubj)
        ? notes
        : notes.Where(n => n.SubjectName == filterSubj);

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        await LoadNotes();
        subjects = await Db.Subjects.Where(s => s.UserId == Auth.CurrentUser!.Id).ToListAsync();
    }

    async Task LoadNotes()
    {
        notes = await Db.Notes.Where(n => n.UserId == Auth.CurrentUser!.Id)
                    .OrderByDescending(n => n.CreatedAt).ToListAsync();
    }

    async Task SaveNote()
    {
        if (string.IsNullOrWhiteSpace(noteTitle)) { noteMsg = "Title is required."; return; }
        if (string.IsNullOrWhiteSpace(noteContent)) { noteMsg = "Content is required."; return; }

        if (editNoteId > 0)
        {
            var existing = await Db.Notes.FindAsync(editNoteId);
            if (existing != null)
            {
                existing.Title = noteTitle;
                existing.Content = noteContent;
                existing.SubjectName = noteSubject;
                await Db.SaveChangesAsync();
            }
            editNoteId = 0;
        }
        else
        {
            var note = new Note
            {
                UserId = Auth.CurrentUser!.Id,
                Title = noteTitle,
                Content = noteContent,
                SubjectName = noteSubject
            };
            Db.Notes.Add(note);
            await Db.SaveChangesAsync();
        }

        noteTitle = ""; noteContent = ""; noteSubject = "";
        noteMsg = "Note saved!";
        await LoadNotes();
        await Task.Delay(1500);
        noteMsg = "";
    }

    void EditNote(Note note)
    {
        editNoteId = note.Id;
        noteTitle = note.Title;
        noteContent = note.Content;
        noteSubject = note.SubjectName ?? "";
    }

    void CancelEdit()
    {
        editNoteId = 0;
        noteTitle = ""; noteContent = ""; noteSubject = "";
    }

    async Task DeleteNote(Note note)
    {
        Db.Notes.Remove(note);
        await Db.SaveChangesAsync();
        await LoadNotes();
    }
}
