@page "/tasks"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="tasks-page">
    <!-- Add Task Form -->
    <div class="dash-card mb-4">
        <h6 class="card-heading">Add New Task</h6>
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <input @bind="newTitle" class="form-control ssp-input" placeholder="Task title..." />
            </div>
            <div class="col-md-3">
                <input @bind="newDesc" class="form-control ssp-input" placeholder="Description (optional)" />
            </div>
            <div class="col-md-2">
                <select @bind="newPriority" class="form-select ssp-input">
                    <option value="High">High Priority</option>
                    <option value="Medium">Medium Priority</option>
                    <option value="Low">Low Priority</option>
                </select>
            </div>
            <div class="col-md-2">
                <input @bind="newDueDate" type="date" class="form-control ssp-input" />
            </div>
            <div class="col-md-1">
                <button class="btn btn-login w-100" @onclick="AddTask">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(msg))
        {
            <div class="alert alert-info py-1 mt-2 small">@msg</div>
        }
    </div>

    <!-- Task Filters -->
    <div class="task-filters mb-3">
        <button class="filter-btn @GetFilterClass("All")" @onclick="SetFilterAll">All (@tasks.Count)</button>
        <button class="filter-btn @GetFilterClass("Pending")" @onclick="SetFilterPending">Pending (@tasks.Count(t => !t.IsCompleted))</button>
        <button class="filter-btn @GetFilterClass("Done")" @onclick="SetFilterDone">Completed (@tasks.Count(t => t.IsCompleted))</button>
    </div>

    <!-- Tasks List -->
    <div class="dash-card">
        @if (!FilteredTasks.Any())
        {
            <div class="text-center py-4 text-muted">No tasks found.</div>
        }
        @foreach (var task in FilteredTasks)
        {
            <div class="task-list-item @(task.IsCompleted ? "task-completed" : "")">
                <input type="checkbox" class="task-check" checked="@task.IsCompleted" @onchange="() => ToggleTask(task)" />
                <div class="task-list-body">
                    @if (editId == task.Id)
                    {
                        <input @bind="editTitle" class="form-control ssp-input mb-1" />
                        <input @bind="editDesc" class="form-control ssp-input" placeholder="Description" />
                    }
                    else
                    {
                        <div class="task-list-title @(task.IsCompleted ? "text-decoration-line-through" : "")">@task.Title</div>
                        @if (!string.IsNullOrEmpty(task.Description))
                        {
                            <div class="task-list-desc">@task.Description</div>
                        }
                    }
                </div>
                <div class="task-list-meta">
                    <span class="priority-badge priority-@task.Priority.ToLower()">@task.Priority</span>
                    @if (task.DueDate.HasValue)
                    {
                        <span class="due-date">@task.DueDate.Value.ToString("MMM dd")</span>
                    }
                </div>
                <div class="task-list-actions">
                    @if (editId == task.Id)
                    {
                        <button class="action-btn text-success" @onclick="() => SaveEdit(task)"><i class="bi bi-check-lg"></i></button>
                        <button class="action-btn text-secondary" @onclick="CancelEdit"><i class="bi bi-x-lg"></i></button>
                    }
                    else
                    {
                        <button class="action-btn text-primary" @onclick="() => StartEdit(task)"><i class="bi bi-pencil"></i></button>
                        <button class="action-btn text-danger" @onclick="() => DeleteTask(task)"><i class="bi bi-trash"></i></button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    List<StudyTask> tasks = new();
    string newTitle = "", newDesc = "", newPriority = "Medium";
    DateTime? newDueDate;
    string msg = "", filter = "All";
    int editId = 0;
    string editTitle = "", editDesc = "";

    string GetFilterClass(string f) => filter == f ? "active" : "";
    void SetFilterAll() => filter = "All";
    void SetFilterPending() => filter = "Pending";
    void SetFilterDone() => filter = "Done";
    void CancelEdit() => editId = 0;

    IEnumerable<StudyTask> FilteredTasks => filter switch
    {
        "Pending" => tasks.Where(t => !t.IsCompleted),
        "Done" => tasks.Where(t => t.IsCompleted),
        _ => tasks
    };

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        await LoadTasks();
    }

    async Task LoadTasks()
    {
        tasks = await Db.StudyTasks.Where(t => t.UserId == Auth.CurrentUser!.Id)
                        .OrderByDescending(t => t.CreatedAt).ToListAsync();
    }

    async Task AddTask()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) { msg = "Title is required."; return; }
        var task = new StudyTask
        {
            UserId = Auth.CurrentUser!.Id,
            Title = newTitle,
            Description = newDesc,
            Priority = newPriority,
            DueDate = newDueDate
        };
        Db.StudyTasks.Add(task);
        await Db.SaveChangesAsync();
        newTitle = ""; newDesc = ""; newPriority = "Medium"; newDueDate = null;
        msg = "Task added!";
        await LoadTasks();
        await Task.Delay(1500);
        msg = "";
    }

    async Task ToggleTask(StudyTask task)
    {
        task.IsCompleted = !task.IsCompleted;
        await Db.SaveChangesAsync();
    }

    void StartEdit(StudyTask task)
    {
        editId = task.Id;
        editTitle = task.Title;
        editDesc = task.Description ?? "";
    }

    async Task SaveEdit(StudyTask task)
    {
        task.Title = editTitle;
        task.Description = editDesc;
        await Db.SaveChangesAsync();
        editId = 0;
    }

    async Task DeleteTask(StudyTask task)
    {
        Db.StudyTasks.Remove(task);
        await Db.SaveChangesAsync();
        await LoadTasks();
    }
}
