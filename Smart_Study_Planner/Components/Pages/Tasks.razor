@page "/tasks"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="task-page-wrapper">

    <!-- Header -->
    <div class="task-header">
        <h2 class="task-page-title">Task Manager</h2>
        <div class="task-stats-box">
            <div class="stat-row"><span>Summary</span><span class="stat-num">@tasks.Count</span></div>
            <div class="stat-row"><span>Completed</span><span class="stat-num">@tasks.Count(t => t.IsCompleted)</span></div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="task-toolbar">
        <button class="btn-add-task" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i> Add Task
        </button>
        <div class="filter-group">
            <select class="filter-select" @bind="filterPriority">
                <option value="">Priority</option>
                <option value="High">High</option>
                <option value="Medium">Medium</option>
                <option value="Low">Low</option>
            </select>
            <select class="filter-select" @bind="filterStatus">
                <option value="">Status</option>
                <option value="Completed">Completed</option>
                <option value="Pending">Pending</option>
                <option value="Scheduled">Scheduled</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    <div class="task-table-wrapper">
        <table class="task-table">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Description</th>
                    <th>Deadline</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in FilteredTasks)
                {
                    <tr>
                        <td class="task-name-cell">@task.Title</td>
                        <td class="task-desc-cell">@task.Description</td>
                        <td class="task-date-cell">
                            @if (task.DueDate.HasValue)
                            {
                                <i class="bi bi-calendar3"></i> 
                                @task.DueDate.Value.ToString("MMM dd")
                            }
                            else
                            {
                                <i class="bi bi-clock"></i>
                            }
                        </td>
                        <td>
                            <span class="status-badge @GetStatusClass(task)">
                                @if (task.IsCompleted)
                                {
                                    <i class="bi bi-check-circle-fill"></i>
                                }
                                @GetStatus(task)
                            </span>
                        </td>
                        <td>
                            <span class="priority-badge @task.Priority.ToLower()">@task.Priority</span>
                        </td>
                        <td class="action-cell">
                            <button class="btn-icon edit" @onclick="() => OpenEditModal(task)">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn-icon delete" @onclick="() => DeleteTask(task)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!FilteredTasks.Any())
                {
                    <tr><td colspan="6" class="no-tasks">No tasks found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add/Edit Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-header-row">
                <h5>@(editingTask == null ? "Add New Task" : "Edit Task")</h5>
                <button class="modal-close" @onclick="CloseModal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body-form">
                <label>Task Name</label>
                <input class="modal-input" @bind="formTitle" placeholder="Enter task name..." />

                <label>Description</label>
                <textarea class="modal-input" @bind="formDesc" placeholder="Enter description..." rows="2"></textarea>

                <label>Priority</label>
                <select class="modal-input" @bind="formPriority">
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>

                <label>Deadline</label>
                <input class="modal-input" type="date" @bind="formDueDate" />

                <label>Status</label>
                <select class="modal-input" @bind="formStatus">
                    <option value="Pending">Pending</option>
                    <option value="Scheduled">Scheduled</option>
                    <option value="Completed">Completed</option>
                </select>

                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="error-msg">@errorMsg</div>
                }

                <button class="btn-save-task" @onclick="SaveTask">
                    @(editingTask == null ? "Add Task" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@code {
    List<StudyTask> tasks = new();
    string filterPriority = "";
    string filterStatus = "";
    bool showModal = false;
    StudyTask? editingTask = null;

    string formTitle = "", formDesc = "", formPriority = "Medium", formStatus = "Pending";
    DateTime? formDueDate;
    string errorMsg = "";

    IEnumerable<StudyTask> FilteredTasks => tasks
        .Where(t => (string.IsNullOrEmpty(filterPriority) || t.Priority == filterPriority))
        .Where(t => string.IsNullOrEmpty(filterStatus) ||
            (filterStatus == "Completed" && t.IsCompleted) ||
            (filterStatus == "Pending" && !t.IsCompleted && t.DueDate == null) ||
            (filterStatus == "Scheduled" && !t.IsCompleted && t.DueDate != null));

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        tasks = await Db.StudyTasks.Where(t => t.UserId == Auth.CurrentUser!.Id).ToListAsync();
    }

    void OpenAddModal()
    {
        editingTask = null;
        formTitle = formDesc = errorMsg = "";
        formPriority = "Medium"; formStatus = "Pending"; formDueDate = null;
        showModal = true;
    }

    void OpenEditModal(StudyTask task)
    {
        editingTask = task;
        formTitle = task.Title;
        formDesc = task.Description ?? "";
        formPriority = task.Priority;
        formStatus = task.IsCompleted ? "Completed" : (task.DueDate != null ? "Scheduled" : "Pending");
        formDueDate = task.DueDate;
        errorMsg = "";
        showModal = true;
    }

    void CloseModal() { showModal = false; errorMsg = ""; }

    async Task SaveTask()
    {
        if (string.IsNullOrWhiteSpace(formTitle)) { errorMsg = "Task name is required."; return; }

        if (editingTask == null)
        {
            var t = new StudyTask
            {
                UserId = Auth.CurrentUser!.Id,
                Title = formTitle,
                Description = formDesc,
                Priority = formPriority,
                IsCompleted = formStatus == "Completed",
                DueDate = formDueDate
            };
            Db.StudyTasks.Add(t);
            await Db.SaveChangesAsync();
            tasks.Add(t);
        }
        else
        {
            editingTask.Title = formTitle;
            editingTask.Description = formDesc;
            editingTask.Priority = formPriority;
            editingTask.IsCompleted = formStatus == "Completed";
            editingTask.DueDate = formDueDate;
            await Db.SaveChangesAsync();
        }
        CloseModal();
    }

    async Task DeleteTask(StudyTask task)
    {
        Db.StudyTasks.Remove(task);
        await Db.SaveChangesAsync();
        tasks.Remove(task);
    }

    string GetStatus(StudyTask t) => t.IsCompleted ? "Completed" : (t.DueDate != null ? "Scheduled" : "Pending");
    string GetStatusClass(StudyTask t) => t.IsCompleted ? "status-completed" : (t.DueDate != null ? "status-scheduled" : "status-pending");
}