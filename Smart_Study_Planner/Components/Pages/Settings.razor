@page "/settings"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="settings-container">
    <div class="settings-header">
        <h2 class="page-title">Settings & Configuration</h2>
        <button class="nav-back-btn" @onclick='() => Nav.NavigateTo("/dashboard")'>
            <i class="bi bi-arrow-right"></i>
        </button>
    </div>

    <div class="settings-laptop-grid">
        <div class="settings-col">
            <div class="glass-card profile-card">
                <div class="card-head-flex">
                    <h6 class="card-heading">Profile</h6>
                    <div class="avatar-large">@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</div>
                </div>
                <div class="profile-details">
                    <span class="p-name">@Auth.CurrentUser?.Name</span>
                    <span class="p-email">@Auth.CurrentUser?.Email</span>
                </div>
                <div class="identity-link mt-4">
                    <span>ASP.NET Identity</span>
                    <a href="javascript:void(0)" class="text-link">Settings <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>

            <div class="glass-card mt-3">
                <h6 class="card-heading mb-3">Appearance</h6>
                <div class="theme-box @(darkTheme ? "is-dark" : "is-light")" @onclick="ToggleTheme">
                    <div class="theme-option">Light Theme</div>
                    <div class="theme-switch-track">
                        <div class="theme-knob"></div>
                    </div>
                    <div class="theme-option">Dark Theme</div>
                </div>
                <div class="small text-muted mt-2 text-center">Module 3 Logic</div>
            </div>
        </div>

        <div class="settings-col">
            <div class="glass-card">
                <h6 class="card-heading">Smart Scheduler Preferences</h6>
                <div class="toggle-item">
                    <span>Difficult subjects get more time</span>
                    <div class="ssp-switch @(smartScheduler ? "active" : "")" @onclick="() => { smartScheduler = !smartScheduler; SaveSettings(); }">
                        <div class="ssp-knob"></div>
                    </div>
                </div>
                <div class="toggle-item">
                    <span>Near exams high priority</span>
                    <div class="ssp-switch @(nearExam ? "active" : "")" @onclick="() => { nearExam = !nearExam; SaveSettings(); }">
                        <div class="ssp-knob"></div>
                    </div>
                </div>
            </div>

            <div class="glass-card mt-3">
                <div class="card-head-flex">
                    <h6 class="card-heading">Notifications</h6>
                    <span class="module-tag">Module 9</span>
                </div>
                <div class="toggle-item">
                    <span>Study time reminders</span>
                    <div class="ssp-switch @(notifyStudy ? "active" : "")" @onclick="() => { notifyStudy = !notifyStudy; SaveSettings(); }">
                        <div class="ssp-knob"></div>
                    </div>
                </div>
                <div class="toggle-item">
                    <span>Email alerts</span>
                    <div class="ssp-switch @(notifyEmail ? "active" : "")" @onclick="() => { notifyEmail = !notifyEmail; SaveSettings(); }">
                        <div class="ssp-knob"></div>
                    </div>
                </div>
            </div>

            <div class="glass-card mt-3">
                <h6 class="card-heading mb-3">Manage Subjects</h6>
                <div class="input-group mb-3">
                    <input @bind="newSubjectName" class="form-control ssp-input" placeholder="New Subject..." />
                    <button class="btn btn-primary px-4" @onclick="AddSubject">Add</button>
                </div>
                <div class="subject-list-scroll">
                    @foreach (var s in subjects)
                    {
                        <div class="subject-row">
                            <div class="s-info">
                                <span class="s-name">@s.Name</span>
                                <span class="s-weakness">Weakness: @s.WeaknessPercent%</span>
                            </div>
                            <button class="trash-btn" @onclick="() => RemoveSubject(s)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="action-footer mt-4">
                <button class="btn btn-outline-danger w-100 mb-2" @onclick="Logout">Logout Account</button>
                <button class="btn btn-light w-100">Account & Privacy</button>
            </div>
        </div>
    </div>
</div>

@code {
    // Logic same rahegi jo aapne di thi
    bool smartScheduler = true, nearExam = true, darkTheme = false, notifyStudy = true, notifyEmail = false;
    List<Subject> subjects = new();
    string newSubjectName = "";
    string saveMsg = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        var u = Auth.CurrentUser!;
        smartScheduler = u.SmartScheduler;
        nearExam = u.NearExamPriority;
        darkTheme = u.DarkTheme;
        notifyStudy = u.NotifyStudyTime;
        notifyEmail = u.NotifyEmail;
        subjects = await Db.Subjects.Where(s => s.UserId == u.Id).ToListAsync();
    }

    async Task SaveSettings()
    {
        var user = await Db.Users.FindAsync(Auth.CurrentUser!.Id);
        if (user == null) return;
        user.SmartScheduler = smartScheduler;
        user.NearExamPriority = nearExam;
        user.DarkTheme = darkTheme;
        user.NotifyStudyTime = notifyStudy;
        user.NotifyEmail = notifyEmail;
        Auth.CurrentUser!.DarkTheme = darkTheme;
        await Db.SaveChangesAsync();
        StateHasChanged();
    }

    void ToggleTheme() { darkTheme = !darkTheme; SaveSettings(); }

    async Task AddSubject()
    {
        if (string.IsNullOrWhiteSpace(newSubjectName)) return;
        var s = new Subject { UserId = Auth.CurrentUser!.Id, Name = newSubjectName, WeaknessPercent = 50 };
        Db.Subjects.Add(s);
        await Db.SaveChangesAsync();
        subjects.Add(s);
        newSubjectName = "";
    }

    async Task RemoveSubject(Subject s)
    {
        Db.Subjects.Remove(s);
        await Db.SaveChangesAsync();
        subjects.Remove(s);
    }

    void Logout() { Auth.Logout(); Nav.NavigateTo("/login"); }
}