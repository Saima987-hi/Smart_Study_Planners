<div class="pomodoro-container">
    <div class="pomodoro-header">
        <h2 class="page-title">Smart Study Pomodoro</h2>
    </div>

    <div class="pomodoro-grid">
        <div class="glass-card timer-main-card">
            <h5 class="card-title">Pomodoro Timer</h5>
            <div class="timer-visual-area">
                <div class="timer-circle">
                    <svg viewBox="0 0 200 200">
                        <circle class="timer-bg" cx="100" cy="100" r="85" />
                        <circle class="timer-progress" cx="100" cy="100" r="85"
                                style="stroke-dasharray: 534; stroke-dashoffset: @(534 - (5.34 * progressPct));" />
                    </svg>
                    <div class="timer-text">
                        <span class="time-main">@FormatTime(secondsLeft)</span>
                    </div>
                </div>
            </div>

            <div class="timer-controls-row">
                <button class="ctrl-btn play-pause" @onclick="StartStop">
                    <i class="bi @(isRunning ? "bi-pause-fill" : "bi-play-fill")"></i>
                </button>
                <button class="ctrl-btn reset" @onclick="Reset">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>

            <p class="session-info">Focus Session @currentSession of 4</p>
        </div>

        <div class="performance-section">
            <div class="glass-card performance-card">
                <div class="card-header-flex">
                    <h5 class="card-title">Performance Tracking</h5>
                    <select class="period-select">
                        <option>Past week</option>
                    </select>
                </div>

                <div class="chart-section">
                    <label class="chart-label">Study Consistency</label>
                    <div class="line-chart-container">
                        <svg viewBox="0 0 400 120" class="main-line-chart">
                            <path class="line-blue" d="M0,100 Q50,80 100,90 T200,60 T300,80 T400,20" fill="none" />
                            <path class="line-light" d="M0,110 Q60,95 120,105 T240,85 T400,50" fill="none" />
                        </svg>
                        <div class="chart-x-axis">
                            <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                        </div>
                    </div>
                </div>

                <div class="bottom-charts-row">
                    <div class="mini-chart-box">
                        <label class="chart-label">Quiz Marks</label>
                        <div class="bar-chart-flex">
                            @foreach (var val in new[] { 40, 60, 35, 75, 50, 65, 85 })
                            {
                                <div class="bar-wrap"><div class="bar-fill" style="height:@(val)%"></div></div>
                            }
                        </div>
                    </div>
                    <div class="mini-chart-box">
                        <label class="chart-label">Assignment Completion</label>
                        <div class="bar-chart-flex">
                            @foreach (var val in new[] { 70, 85, 60, 95, 75, 80, 100 })
                            {
                                <div class="bar-wrap"><div class="bar-fill" style="height:@(val)%"></div></div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="gamification-badge">
                <h6 class="badge-title">Gamification</h6>
                <div class="badge-stats">
                    <span>XP points: <strong>@(Auth.CurrentUser?.XpPoints ?? 1250)</strong></span>
                    <span class="streak-label">🔥 @(Auth.CurrentUser?.StreakDays ?? 7) Day Streak</span>
                </div>
            </div>
        </div>
    </div>
</div>
@code {
    private System.Threading.Timer? timer;
    private int totalSeconds = 25 * 60;
    private int secondsLeft = 25 * 60;
    private bool isRunning = false;
    private int currentSession = 1;

    // Is progressPct variable ka error aa raha tha
    private double progressPct => 100.0 - (secondsLeft * 100.0 / totalSeconds);

    // Is method ka error aa raha tha
    private string FormatTime(int s) => $"{s / 60:D2}:{s % 60:D2}";

    private void StartStop()
    {
        if (isRunning)
        {
            timer?.Dispose();
            timer = null;
            isRunning = false;
        }
        else
        {
            isRunning = true;
            timer = new System.Threading.Timer(async _ =>
            {
                if (secondsLeft > 0)
                {
                    secondsLeft--;
                    await InvokeAsync(StateHasChanged);
                }
                else
                {
                    isRunning = false;
                    timer?.Dispose();
                    timer = null;
                    if (currentSession < 4) currentSession++;
                    else currentSession = 1;
                    secondsLeft = totalSeconds;
                    await SaveSession();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, 0, 1000);
        }
    }

    private void Reset()
    {
        timer?.Dispose();
        timer = null;
        isRunning = false;
        secondsLeft = totalSeconds;
    }

    private async Task SaveSession()
    {
        if (!Auth.IsLoggedIn) return;

        var session = new PomodoroSession
        {
            UserId = Auth.CurrentUser!.Id,
            DurationMinutes = 25,
            IsCompleted = true
        };

        Db.PomodoroSessions.Add(session);

        var user = await Db.Users.FindAsync(Auth.CurrentUser.Id);
        if (user != null)
        {
            user.XpPoints += 50;
            // Streak logic yahan add ho sakti hai
        }

        await Db.SaveChangesAsync();
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}