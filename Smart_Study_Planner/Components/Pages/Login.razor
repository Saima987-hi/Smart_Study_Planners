@page "/login"
@using System.ComponentModel.DataAnnotations

<PageTitle>Smart Study Planner - Login</PageTitle>

<div class="login-wrapper">
    <!-- Left Panel -->
    <div class="left-panel">
        <div class="circle circle-1"></div>
        <div class="circle circle-2"></div>
        <div class="circle circle-3"></div>
        <div class="geometric geo-1"></div>
        <div class="geometric geo-2"></div>
        <div class="brand-content">
            <h1 class="brand-title">Smart Study Planner</h1>
            <p class="brand-subtitle">Unlock your academic potential</p>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">
        <div class="login-card">
            <!-- Logo -->
            <div class="logo-container">
                <svg class="logo-svg" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M30 5 L10 52 L22 52 L30 32 L38 52 L50 52 Z" fill="url(#logoGrad)" stroke-width="0" />
                    <path d="M15 38 L45 38" stroke="url(#logoGrad)" stroke-width="3" stroke-linecap="round" />
                    <path d="M30 5 Q40 20 30 32" stroke="#2563EB" stroke-width="2.5" fill="none" stroke-linecap="round" />
                    <defs>
                        <linearGradient id="logoGrad" x1="10" y1="5" x2="50" y2="52" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#4A7FC1" />
                            <stop offset="100%" stop-color="#1E3A5F" />
                        </linearGradient>
                    </defs>
                </svg>
            </div>

            <!-- Login Form -->
            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" class="login-form">
                <DataAnnotationsValidator />

                <!-- Email Field -->
                <div class="input-group @(emailFocused ? "focused" : "")">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="2" y="4" width="20" height="16" rx="3" />
                            <path d="M2 7 L12 13 L22 7" />
                        </svg>
                    </span>
                    <InputText @bind-Value="loginModel.Email"
                               class="form-input"
                               placeholder="Email Address"
                               type="email"
                               @onfocus="() => emailFocused = true"
                               @onblur="() => emailFocused = false" />
                    <ValidationMessage For="@(() => loginModel.Email)" class="validation-msg" />
                </div>

                <!-- Password Field -->
                <div class="input-group @(passwordFocused ? "focused" : "")">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="5" y="11" width="14" height="10" rx="2" />
                            <path d="M8 11V7a4 4 0 0 1 8 0v4" />
                        </svg>
                    </span>
                    <InputText @bind-Value="loginModel.Password"
                               class="form-input"
                               placeholder="Password"
                               type="@(showPassword ? "text" : "password")"
                               @onfocus="() => passwordFocused = true"
                               @onblur="() => passwordFocused = false" />
                    <button type="button" class="toggle-password" @onclick="TogglePassword">
                        @if (showPassword)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                <line x1="1" y1="1" x2="23" y2="23" />
                            </svg>
                        }
                    </button>
                    <ValidationMessage For="@(() => loginModel.Password)" class="validation-msg" />
                </div>

                <!-- Forgot Password -->
                <div class="forgot-row">
                    <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
                </div>

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-alert">@errorMessage</div>
                }

                <!-- Login Button -->
                <button type="submit" class="btn-login" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner"></span>
                        <span>Logging in...</span>
                    }
                    else
                    {
                        <span>Login</span>
                    }
                </button>

                <!-- Register Button -->
                <a href="/register" class="btn-register">
                    Register as Student
                </a>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private bool showPassword = false;
    private bool isLoading = false;
    private bool emailFocused = false;
    private bool passwordFocused = false;
    private string errorMessage = string.Empty;

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();

        // Simulate API call delay
        await Task.Delay(1200);

        // TODO: Replace with actual authentication logic
        // Example:
        // var result = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);
        // if (result.Success) Navigation.NavigateTo("/dashboard");
        // else errorMessage = result.Message;

        // Demo check
        if (loginModel.Email == "student@test.com" && loginModel.Password == "password123")
        {
            // Navigation.NavigateTo("/dashboard");
            errorMessage = string.Empty;
        }
        else
        {
            errorMessage = "Invalid email or password. Please try again.";
        }

        isLoading = false;
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;
    }
}
