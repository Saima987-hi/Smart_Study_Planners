@page "/"
@page "/login"
@using Smart_Study_Planner.Services
@inject AuthService Auth
@inject NavigationManager Nav

@if (Auth.IsLoggedIn)
{
    Nav.NavigateTo("/dashboard");
    return;
}

<div class="login-wrapper">
    <div class="login-left">
        <div class="login-left-content">
            <h1 class="login-headline">Smart Study Planner</h1>
            <p class="login-tagline">Unlock your academic potential</p>
        </div>
        <div class="decor-circles"></div>
    </div>

    <div class="login-right">
        <div class="login-card shadow-sm">
            <div class="login-logo-container">
                <div class="custom-logo">A</div>
            </div>

            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert alert-danger py-2 mb-3 small">@errorMsg</div>
            }

            <div class="login-form">
                @if (!isRegister)
                {
                    <div class="input-container">
                        <i class="bi bi-envelope"></i>
                        <input @bind="email" type="email" placeholder="Email Address" />
                    </div>

                    <div class="input-container">
                        <i class="bi bi-lock"></i>
                        <input @bind="password" type="@passType" placeholder="Password" />
                        <button class="pass-toggle-btn" @onclick="TogglePass">
                            <i class="bi @eyeIcon"></i>
                        </button>
                    </div>

                    <div class="forgot-password-box">
                        <a href="javascript:void(0)" class="forgot-link">Forgot Password?</a>
                    </div>

                    <button class="btn btn-main-login" @onclick="DoLogin" disabled="@loading">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Login
                    </button>
                    @if (!string.IsNullOrEmpty(successMsg))
                    {
                        <p class="text-success">@successMsg</p>
                    }
                    <button class="btn btn-outline-register" @onclick="GoToRegister">
                        Register as Student
                    </button>
                }
                else
                {
                    <div class="input-container">
                        <i class="bi bi-person"></i>
                        <input @bind="name" type="text" placeholder="Full Name" />
                    </div>
                    <div class="input-container">
                        <i class="bi bi-envelope"></i>
                        <input @bind="email" type="email" placeholder="Email Address" />
                    </div>
                    <div class="input-container">
                        <i class="bi bi-lock"></i>
                        <input @bind="password" type="@passType" placeholder="Password" />
                    </div>

                    <button class="btn btn-main-login" @onclick="DoRegister" disabled="@loading">
                        Create Account
                    </button>
                    <button class="btn btn-outline-register" @onclick="GoToLogin">
                        Back to Login
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    string email = "", password = "", name = "";
    string errorMsg = "", successMsg = "";
    bool loading = false, showPass = false, isRegister = false;

    string passType => showPass ? "text" : "password";
    string eyeIcon => showPass ? "bi-eye-slash" : "bi-eye";

    void TogglePass() => showPass = !showPass;
    void GoToRegister() { isRegister = false; isRegister = true; errorMsg = ""; }
    void GoToLogin() { isRegister = false; errorMsg = ""; }

    async Task DoLogin()
    {
        loading = true; errorMsg = "";
        var (ok, msg) = await Auth.LoginAsync(email, password);
        loading = false;
        if (ok) Nav.NavigateTo("/dashboard");
        else errorMsg = msg;
    }

    async Task DoRegister()
    {
        loading = true; errorMsg = "";
        if (string.IsNullOrWhiteSpace(name)) { errorMsg = "Name is required."; loading = false; return; }
        var (ok, msg) = await Auth.RegisterAsync(name, email, password);
        loading = false;
        if (ok) Nav.NavigateTo("/dashboard");
        else errorMsg = msg;
    }
}