@page "/"
@page "/login"
@using Smart_Study_Planner.Services
@inject AuthService Auth
@inject NavigationManager Nav

<div class="login-wrapper">
    <!-- Left Panel -->
    <div class="login-left">
        <div class="login-left-content">
            <div class="login-circles">
                <div class="circle c1"></div>
                <div class="circle c2"></div>
                <div class="circle c3"></div>
            </div>
            <h1 class="login-headline">Smart Study Planner</h1>
            <p class="login-tagline">Unlock your academic potential</p>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="login-right">
        <div class="login-card">
            <div class="login-logo">
                <span>A</span>
            </div>

            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert alert-danger py-2 small">@errorMsg</div>
            }

            @if (!isRegister)
            {
                <div class="login-form">
                    <div class="input-group-custom">
                        <i class="bi bi-envelope"></i>
                        <input @bind="email" type="email" class="form-control" placeholder="Email Address" />
                    </div>
                    <div class="input-group-custom">
                        <i class="bi bi-lock"></i>
                        <input @bind="password" type="@passType" class="form-control" placeholder="Password" />
                        <button class="pass-toggle" @onclick="TogglePass">
                            <i class="bi @eyeIcon"></i>
                        </button>
                    </div>
                    <div class="text-end mb-3">
                        <a href="#" class="forgot-link">Forgot Password?</a>
                    </div>
                    <button class="btn btn-login" @onclick="DoLogin" disabled="@loading">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Login
                    </button>
                    <button class="btn btn-register" @onclick="GoToRegister">
                        Register as Student
                    </button>
                </div>
            }
            else
            {
                <div class="login-form">
                    <div class="input-group-custom">
                        <i class="bi bi-person"></i>
                        <input @bind="name" type="text" class="form-control" placeholder="Full Name" />
                    </div>
                    <div class="input-group-custom">
                        <i class="bi bi-envelope"></i>
                        <input @bind="email" type="email" class="form-control" placeholder="Email Address" />
                    </div>
                    <div class="input-group-custom">
                        <i class="bi bi-lock"></i>
                        <input @bind="password" type="@passType" class="form-control" placeholder="Password" />
                        <button class="pass-toggle" @onclick="TogglePass">
                            <i class="bi @eyeIcon"></i>
                        </button>
                    </div>
                    <button class="btn btn-login" @onclick="DoRegister" disabled="@loading">
                        @if (loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Create Account
                    </button>
                    <button class="btn btn-register" @onclick="GoToLogin">
                        Back to Login
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    string email = "", password = "", name = "";
    string errorMsg = "";
    bool loading = false, showPass = false, isRegister = false;

    string passType => showPass ? "text" : "password";
    string eyeIcon => showPass ? "bi-eye-slash" : "bi-eye";

    void TogglePass() => showPass = !showPass;
    void GoToRegister() { isRegister = true; errorMsg = ""; }
    void GoToLogin() { isRegister = false; errorMsg = ""; }

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/dashboard", forceLoad: false);
    }

    async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMsg = "Please enter email and password.";
            return;
        }
        loading = true;
        errorMsg = "";
        StateHasChanged();
        var (ok, msg) = await Auth.LoginAsync(email, password);
        loading = false;
        if (ok) Nav.NavigateTo("/dashboard", forceLoad: false);
        else errorMsg = msg;
    }

    async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(name)) { errorMsg = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMsg = "Email and password are required.";
            return;
        }
        loading = true;
        errorMsg = "";
        StateHasChanged();
        var (ok, msg) = await Auth.RegisterAsync(name, email, password);
        loading = false;
        if (ok) Nav.NavigateTo("/dashboard", forceLoad: false);
        else errorMsg = msg;
    }
}
