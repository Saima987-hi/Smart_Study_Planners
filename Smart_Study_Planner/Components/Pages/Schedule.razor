@page "/schedule"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="schedule-container">
    <div class="schedule-header">
        <h2>Smart Study Scheduler</h2>
        <div class="header-icons">
            <i class="bi bi-bell"></i>
            <div class="header-avatar">A</div>
        </div>
    </div>

    <div class="schedule-grid">
        <div class="dash-card schedule-input-card">
            <h5 class="card-title">Input Parameters</h5>

            <div class="input-section">
                <label>Subjects</label>
                <div class="tags-container">
                    @foreach (var s in selectedSubjects)
                    {
                        <span class="subject-tag">@s <i class="bi bi-x" @onclick="() => selectedSubjects.Remove(s)"></i></span>
                    }
                    <div class="add-tag-box">
                        <select @bind="subjectInput" @onblur="AddSubject">
                            <option value="">+</option>
                            @foreach (var s in allSubjects)
                            {
                                <option value="@s.Name">@s.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="input-section">
                <label>Exam Dates</label>
                <div class="date-row">
                    <div class="date-input"><i class="bi bi-calendar3"></i><input type="date" @bind="examDate1" /></div>
                    <div class="date-input"><i class="bi bi-calendar3"></i><input type="date" @bind="examDate2" /></div>
                </div>
            </div>

            <div class="input-section">
                <label>Available Hours</label>
                <select @bind="availableHours" class="full-select">
                    <option value="2">2 hrs/day</option>
                    <option value="4">4 hrs/day</option>
                    <option value="6">6 hrs/day</option>
                </select>
            </div>

            <button class="btn-generate" @onclick="GenerateSchedule">Generate Timetable</button>
        </div>

        <div class="timetable-section">
            <div class="dash-card schedule-table-card">
                <h5 class="card-title">Generated Timetable (This Week)</h5>

                <div class="day-container">
                    <div class="day-label-main">Monday</div>
                    <div class="slots-list">
                        @foreach (var slot in timeSlots)
                        {
                            var entry = scheduleEntries.FirstOrDefault(e => e.DayOfWeek == "Monday" && e.TimeSlot == slot);
                            <div class="time-row">
                                <div class="time-box">@slot</div>
                                <div class="slot-content @(entry?.IsAiSuggested == true ? "ai-border" : "")">
                                    <span>@entry?.Title</span>
                                    @if (entry?.IsAiSuggested == true)
                                    {
                                        <span class="ai-badge">AI Suggested</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="task-mgmt-popup shadow">
                <h6 class="task-mgmt-title">Task Management</h6>
                @foreach (var task in taskList)
                {
                    <div class="mgmt-row">
                        <span class="t-title">@task.Title</span>
                        <span class="p-badge @task.Priority.ToLower()">@task.Priority</span>
                        <input type="checkbox" checked="@task.IsCompleted" @onchange="() => ToggleMgmtTask(task)" />
                    </div>
                }
            </div>
        </div>
    </div>
</div>