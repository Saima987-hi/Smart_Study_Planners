@* FILE: Smart_Study_Planner/Components/Pages/DashBoard.razor *@
@* REPLACE your entire DashBoard.razor with this *@

@page "/dashboard"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="dashboard-grid">
    <!-- Welcome + Progress Card -->
    <div class="dash-card welcome-card">
        <div class="welcome-info">
            <div class="user-avatar-lg">
                <span>@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</span>
            </div>
            <div>
                <p class="welcome-label">Welcome,</p>
                <h3 class="welcome-name">@Auth.CurrentUser?.Name!</h3>
                <small class="text-muted">🔥 @(Auth.CurrentUser?.StreakDays ?? 0) day streak &nbsp;|&nbsp; ⭐ @(Auth.CurrentUser?.XpPoints ?? 0) XP</small>
            </div>
        </div>
        <div class="progress-circle-wrap">
            <p class="progress-label">Tasks Progress</p>
            <div class="progress-circle">
                <svg viewBox="0 0 100 100" width="100" height="100">
                    <circle cx="50" cy="50" r="40" fill="none" stroke="#e0e8f5" stroke-width="10" />
                    <circle cx="50" cy="50" r="40" fill="none" stroke="#2d5fa0" stroke-width="10"
                            stroke-dasharray="@dashValue @dashRemainder"
                            stroke-dashoffset="62.75" stroke-linecap="round" />
                </svg>
                <span class="progress-pct">@overallProgress%</span>
            </div>
        </div>
    </div>

    <!-- Today's Tasks -->
    <div class="dash-card tasks-card">
        <h6 class="card-heading">Today's Tasks</h6>
        @if (todayTasks.Any())
        {
            @foreach (var t in todayTasks)
            {
                <div class="task-item">
                    <input type="checkbox" checked="@t.IsCompleted" @onchange="() => ToggleTask(t)" />
                    <span class="@(t.IsCompleted ? "task-done" : "")">@t.Title</span>
                    <span class="priority-badge priority-@t.Priority.ToLower() ms-auto">@t.Priority</span>
                </div>
            }
        }
        else
        {
            <p class="text-muted small">No tasks yet. Add from My Tasks page.</p>
        }
    </div>

    <!-- Study Hours Chart -->
    <div class="dash-card chart-card">
        <h6 class="card-heading">Study Hours This Week</h6>
        <div class="bar-chart">
            @if (!studyLogs.Any())
            {
                <p class="text-muted small">No study data yet.</p>
            }
            @foreach (var log in studyLogs)
            {
                <div class="bar-col">
                    <div class="bar" style="@GetBarStyle(log.HoursStudied)"></div>
                    <span class="bar-label">@log.Date.ToString("ddd")</span>
                </div>
            }
        </div>
    </div>

    <!-- Upcoming Exams -->
    <div class="dash-card exams-card">
        <h6 class="card-heading">Upcoming Exams</h6>
        @if (!upcomingExams.Any())
        {
            <p class="text-muted small">No upcoming exams.</p>
        }
        @foreach (var ex in upcomingExams)
        {
            int daysLeft = (int)(ex.ExamDate - DateTime.Today).TotalDays;
            <div class="exam-row">
                <div>
                    <div class="exam-subject">@ex.SubjectName</div>
                    <div class="exam-course">@ex.CourseName</div>
                </div>
                <div class="exam-date">
                    @if (daysLeft == 0)
                    {
                        <span class="text-danger fw-bold">Today!</span>
                    }
                    else if (daysLeft == 1)
                    {

                        <span class="text-warning fw-bold">Tomorrow</span>
                    }
                    else
                    {

                        <span>@daysLeft days left</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Weak Subjects -->
    <div class="dash-card weak-card">
        <h6 class="card-heading">Weak Subjects</h6>
        @if (!weakSubjects.Any())
        {
            <p class="text-muted small">No subjects added yet.</p>
        }
        @foreach (var s in weakSubjects)
        {
            <div class="weak-row">
                <span class="weak-name">@s.Name</span>
                <div class="weak-bar-wrap">
                    <div class="weak-bar" style="@GetWeakBarStyle(s.WeaknessPercent)"></div>
                </div>
                <span class="weak-pct">@s.WeaknessPercent%</span>
            </div>
        }
    </div>
</div>

@code {
    List<StudyTask> todayTasks = new();
    List<StudyLog> studyLogs = new();
    List<Exam> upcomingExams = new();
    List<Subject> weakSubjects = new();
    // ✅ FIX: Overall progress — poore DB se calculate hota hai
    int overallProgress = 0;
    double maxH = 10;

    double dashValue => 2.51 * overallProgress;
    double dashRemainder => 251 - 2.51 * overallProgress;

    string GetBarStyle(double hours)
    {
        double h = maxH == 0 ? 1 : maxH;
        int px = (int)(hours / h * 120);
        return "height:" + px + "px";
    }

    string GetWeakBarStyle(int pct) => "width:" + pct + "%";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        int uid = Auth.CurrentUser!.Id;

        todayTasks = await Db.StudyTasks.Where(t => t.UserId == uid).OrderByDescending(t => t.CreatedAt).Take(5).ToListAsync();
        studyLogs = await Db.StudyLogs.Where(l => l.UserId == uid).OrderBy(l => l.Date).Take(7).ToListAsync();
        upcomingExams = await Db.Exams.Where(e => e.UserId == uid && e.ExamDate >= DateTime.Today).OrderBy(e => e.ExamDate).Take(3).ToListAsync();
        weakSubjects = await Db.Subjects.Where(s => s.UserId == uid).OrderByDescending(s => s.WeaknessPercent).Take(3).ToListAsync();

        maxH = studyLogs.Any() ? studyLogs.Max(l => l.HoursStudied) : 10;

        // ✅ FIX: Poore tasks ka progress — sirf 4 tasks nahi
        int total = await Db.StudyTasks.CountAsync(t => t.UserId == uid);
        int done = await Db.StudyTasks.CountAsync(t => t.UserId == uid && t.IsCompleted);
        overallProgress = total > 0 ? (int)(done * 100.0 / total) : 0;
    }

    async Task ToggleTask(StudyTask task)
    {
        task.IsCompleted = !task.IsCompleted;
        var dbTask = await Db.StudyTasks.FindAsync(task.Id);
        if (dbTask != null)
        {
            dbTask.IsCompleted = task.IsCompleted;
            await Db.SaveChangesAsync();
        }
        int total = await Db.StudyTasks.CountAsync(t => t.UserId == Auth.CurrentUser!.Id);
        int done = await Db.StudyTasks.CountAsync(t => t.UserId == Auth.CurrentUser!.Id && t.IsCompleted);
        overallProgress = total > 0 ? (int)(done * 100.0 / total) : 0;
    }
}
