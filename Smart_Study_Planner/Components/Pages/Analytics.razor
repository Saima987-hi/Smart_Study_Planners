@page "/analytics"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="analytics-page-container">
    <div class="analytics-header">
        <h2 class="page-title">Analytics & Reports</h2>
        <div class="user-profile-badge">
            <div class="avatar-circle">@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</div>
            <div class="user-meta">
                <span class="u-name">@Auth.CurrentUser?.Name</span>
                <span class="u-role">Student Dashboard <i class="bi bi-chevron-right"></i></span>
            </div>
        </div>
    </div>

    <div class="analytics-main-grid">
        <div class="glass-card chart-card-lg">
            <div class="card-head-flex">
                <h6 class="card-heading">Weekly Efficiency</h6>
                <span class="module-tag">Module 12/11</span>
            </div>
            <div class="chart-content">
                <svg viewBox="0 0 400 150" class="smooth-line-chart">
                    <path d="M0,130 Q50,110 100,120 T200,80 T300,100 T400,20" fill="none" stroke="#3182ce" stroke-width="3" />
                    <circle cx="150" cy="110" r="4" fill="#3182ce" />
                    <text x="155" y="105" font-size="10" fill="#3182ce" font-weight="bold">XP</text>
                    <circle cx="250" cy="85" r="4" fill="#3182ce" />
                    <text x="255" y="80" font-size="10" fill="#3182ce" font-weight="bold">XP</text>
                </svg>
            </div>
        </div>

        <div class="glass-card chart-card-md">
            <div class="card-head-flex">
                <h6 class="card-heading">Subject-wise Time Spent</h6>
                <span class="module-tag">Module 12 <span class="dot-red">●</span></span>
            </div>
            <div class="bar-chart-container">
                @foreach (var subj in subjects)
                {
                    <div class="stacked-bar-col">
                        <div class="bar-stack">
                            <div class="segment s1" style="height: 30%"></div>
                            <div class="segment s2" style="height: 40%"></div>
                            <div class="segment s3" style="height: 20%"></div>
                        </div>
                        <span class="bar-label">@subj.Name</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="analytics-bottom-grid mt-4">
        <div class="glass-card donut-card">
            <div class="card-head-flex">
                <h6 class="card-heading">Assignment Completion</h6>
                <span class="module-tag">Module 7</span>
            </div>
            <div class="donut-visual">
                <svg viewBox="0 0 100 100" class="donut-svg">
                    <circle cx="50" cy="50" r="40" fill="transparent" stroke="#e2e8f0" stroke-width="10" />
                    <circle cx="50" cy="50" r="40" fill="transparent" stroke="#2b6cb0" stroke-width="10" stroke-dasharray="180 251" stroke-dashoffset="0" />
                </svg>
                <div class="donut-center">
                    <span class="pct">72%</span>
                </div>
            </div>
        </div>

        <div class="metrics-grid">
            <div class="mini-metric-card">
                <span class="m-val">@totalStudyHours</span>
                <span class="m-lbl">Total Hours</span>
            </div>
            <div class="mini-metric-card highlight">
                <span class="m-val">@consistencyPct%</span>
                <span class="m-lbl">Consistency</span>
            </div>
            <div class="mini-metric-card">
                <span class="m-val">@tasksCompleted</span>
                <span class="m-lbl">Tasks Done</span>
            </div>
            <div class="mini-metric-card warning">
                <span class="m-val">@weakAreas</span>
                <span class="m-lbl">Weak Areas</span>
            </div>
        </div>
    </div>
</div>