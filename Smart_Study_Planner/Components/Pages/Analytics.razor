@page "/analytics"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="analytics-header-row mb-3">
    <div class="user-info-badge">
        <div class="user-avatar">@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</div>
        <div>
            <div class="fw-semibold">@Auth.CurrentUser?.Name</div>
            <div class="small text-muted">ASP.NET Identity</div>
        </div>
    </div>
</div>

<div class="analytics-charts-row">
    <!-- Study Hours & Efficiency -->
    <div class="dash-card">
        <h6 class="card-heading">Study Hours &amp; Efficiency <span class="text-muted small">(Past Month)</span></h6>
        <div class="line-chart-wrap">
            <svg viewBox="0 0 360 120" width="100%" height="120">
                <polyline fill="none" stroke="#2d5fa0" stroke-width="2.5"
                          points="0,110 60,90 120,70 180,80 240,40 300,20 360,5" />
                <circle cx="180" cy="80" r="5" fill="#2d5fa0" />
                <text x="185" y="75" font-size="10" fill="#2d5fa0">Module 12/2</text>
            </svg>
            <div class="chart-days">
                @foreach (var m in new[] { "Mon", "Jul", "Nov", "Dec", "Jan", "Feb" })
                {
                    <span>@m</span>
                }
            </div>
        </div>
    </div>

    <!-- Subject-wise Performance -->
    <div class="dash-card">
        <h6 class="card-heading">Subject-wise Performance <span class="text-muted small">(Quiz &amp; Assignment)</span></h6>
        <div class="grouped-bar-chart">
            @foreach (var subj in subjects)
            {
                <div class="grouped-bar-col">
                    <div class="grouped-bars">
                        <div class="gbar gbar-dark" style="@GbarStyle(subj.Quiz)" title="Quiz: @subj.Quiz%">
                            <span class="gbar-label">@subj.Quiz%</span>
                        </div>
                        <div class="gbar gbar-mid" style="@GbarStyle(subj.Assignment)" title="Assign: @subj.Assignment%">
                            <span class="gbar-label">@subj.Assignment%</span>
                        </div>
                    </div>
                    <span class="bar-label">@subj.Name</span>
                </div>
            }
        </div>
    </div>

    <!-- Subject Weakness Radar -->
    <div class="dash-card">
        <h6 class="card-heading">Subject Weakness Analysis</h6>
        <div class="radar-wrap">
            <svg viewBox="0 0 200 200" width="180" height="180">
                <polygon points="100,20 180,60 180,140 100,180 20,140 20,60" fill="none" stroke="#dce8f5" stroke-width="1" />
                <polygon points="100,40 160,70 160,130 100,160 40,130 40,70" fill="none" stroke="#dce8f5" stroke-width="1" />
                <polygon points="100,60 140,80 140,120 100,140 60,120 60,80" fill="none" stroke="#dce8f5" stroke-width="1" />
                <polygon points="100,35 165,65 155,135 100,168 35,130 40,62"
                         fill="rgba(45,95,160,0.2)" stroke="#2d5fa0" stroke-width="2" />
                <text x="94" y="15" font-size="9" fill="#444">Coverage</text>
                <text x="182" y="62" font-size="9" fill="#444">OOP</text>
                <text x="182" y="142" font-size="9" fill="#444">NOP</text>
                <text x="75" y="193" font-size="9" fill="#444">Networking</text>
                <text x="2" y="142" font-size="9" fill="#444">Physics</text>
                <text x="8" y="62" font-size="9" fill="#444">Math</text>
            </svg>
        </div>
    </div>
</div>

<!-- Key Metrics -->
<div class="key-metrics-row mt-3">
    <div class="metric-card">
        <span class="metric-label">Total Study Time (Hrs)</span>
        <span class="metric-value">@totalStudyHours hrs</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Overall Consistency (%)</span>
        <span class="metric-value">@consistencyPct%</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Tasks Completed</span>
        <span class="metric-value">@tasksCompleted</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Weak Areas Identified</span>
        <span class="metric-value">@weakAreas</span>
    </div>
</div>

@code {
    record SubjectStat(string Name, int Quiz, int Assignment);
    List<SubjectStat> subjects = new()
    {
        new("Math", 20, 28),
        new("OOP", 40, 50),
        new("Networking", 23, 51),
        new("Physics", 17, 21)
    };

    double totalStudyHours = 6;
    int consistencyPct = 60;
    int tasksCompleted = 13;
    int weakAreas = 11;

    string GbarStyle(int val) => "height:" + (int)(val * 1.2) + "px";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        int uid = Auth.CurrentUser!.Id;
        var logs = await Db.StudyLogs.Where(l => l.UserId == uid).ToListAsync();
        totalStudyHours = Math.Round(logs.Sum(l => l.HoursStudied), 1);
        tasksCompleted = await Db.StudyTasks.CountAsync(t => t.UserId == uid && t.IsCompleted);
        weakAreas = await Db.Subjects.CountAsync(s => s.UserId == uid && s.WeaknessPercent > 60);
        consistencyPct = logs.Any() ? (int)(logs.Average(l => l.HoursStudied) / 10 * 100) : 60;
    }
}
