@* FILE: Smart_Study_Planner/Components/Pages/Analytics.razor *@
@* REPLACE your entire Analytics.razor with this *@

@page "/analytics"
@using Smart_Study_Planner.Services
@using Smart_Study_Planner.Models
@using Smart_Study_Planner.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService Auth
@inject AppDbContext Db
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }

<div class="analytics-header-row mb-3">
    <div class="user-info-badge">
        <div class="user-avatar">@(Auth.CurrentUser?.Name?.Substring(0, 1).ToUpper())</div>
        <div>
            <div class="fw-semibold">@Auth.CurrentUser?.Name</div>
            <div class="small text-muted">Smart Study Planner</div>
        </div>
    </div>
</div>

<div class="analytics-charts-row">
    <!-- ✅ FIX: Study Hours — real DB data se chart -->
    <div class="dash-card">
        <h6 class="card-heading">Study Hours This Week</h6>
        <div class="bar-chart" style="height:120px;">
            @if (!studyLogs.Any())
            {
                <p class="text-muted small">No study logs yet. Complete Pomodoro sessions to track hours.</p>
            }
            @foreach (var log in studyLogs)
            {
                <div class="bar-col">
                    <div class="bar" style="@GetBarStyle(log.HoursStudied)"></div>
                    <span class="bar-label">@log.Date.ToString("ddd")</span>
                </div>
            }
        </div>
    </div>

    <!-- ✅ FIX: Subject Performance — real DB subjects se -->
    <div class="dash-card">
        <h6 class="card-heading">Subject Weakness Analysis</h6>
        @if (!dbSubjects.Any())
        {
            <p class="text-muted small">No subjects added yet.</p>
        }
        @foreach (var s in dbSubjects)
        {
            <div class="weak-row mb-2">
                <span class="weak-name">@s.Name</span>
                <div class="weak-bar-wrap">
                    <div class="weak-bar" style="width:@s.WeaknessPercent%"></div>
                </div>
                <span class="weak-pct">@s.WeaknessPercent%</span>
            </div>
        }
    </div>

    <!-- AI Recommendations Panel -->
    <div class="dash-card">
        <h6 class="card-heading">AI Recommendations</h6>
        @if (!recommendations.Any())
        {
            <p class="text-muted small">Great job! Keep studying consistently.</p>
        }
        @foreach (var rec in recommendations)
        {
            <div class="ai-rec-item">
                <i class="bi bi-lightbulb-fill text-warning me-2"></i>
                <span>@rec</span>
            </div>
        }
    </div>
</div>

<!-- ✅ FIX: Key Metrics — real DB se calculate -->
<div class="key-metrics-row mt-3">
    <div class="metric-card">
        <span class="metric-label">Total Study Time</span>
        <span class="metric-value">@totalStudyHours hrs</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Consistency</span>
        <span class="metric-value">@consistencyPct%</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Tasks Completed</span>
        <span class="metric-value">@tasksCompleted</span>
    </div>
    <div class="metric-card">
        <span class="metric-label">Weak Subjects</span>
        <span class="metric-value">@weakAreas</span>
    </div>
</div>

<!-- Pomodoro Sessions This Week -->
<div class="dash-card mt-3">
    <h6 class="card-heading">Pomodoro Sessions & XP</h6>
    <div class="d-flex gap-4 align-items-center">
        <div>
            <div class="metric-value" style="font-size:1.3rem">@pomodoroCount</div>
            <div class="metric-label">Sessions Completed</div>
        </div>
        <div>
            <div class="metric-value" style="font-size:1.3rem">@(Auth.CurrentUser?.XpPoints ?? 0)</div>
            <div class="metric-label">Total XP Points</div>
        </div>
        <div>
            <div class="metric-value" style="font-size:1.3rem">🔥 @(Auth.CurrentUser?.StreakDays ?? 0)</div>
            <div class="metric-label">Day Streak</div>
        </div>
    </div>
</div>

@code {
    List<StudyLog> studyLogs = new();
    List<Subject> dbSubjects = new();
    List<string> recommendations = new();
    double totalStudyHours = 0;
    int consistencyPct = 0;
    int tasksCompleted = 0;
    int weakAreas = 0;
    int pomodoroCount = 0;
    double maxH = 10;

    string GetBarStyle(double hours)
    {
        double h = maxH == 0 ? 1 : maxH;
        int px = (int)(hours / h * 110);
        return "height:" + px + "px";
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        int uid = Auth.CurrentUser!.Id;

        // ✅ FIX: Sab real DB se
        var today = DateTime.Today;
        studyLogs = await Db.StudyLogs.Where(l => l.UserId == uid && l.Date >= today.AddDays(-6)).OrderBy(l => l.Date).ToListAsync();
        dbSubjects = await Db.Subjects.Where(s => s.UserId == uid).OrderByDescending(s => s.WeaknessPercent).ToListAsync();

        totalStudyHours = Math.Round(studyLogs.Sum(l => l.HoursStudied), 1);
        tasksCompleted = await Db.StudyTasks.CountAsync(t => t.UserId == uid && t.IsCompleted);
        weakAreas = dbSubjects.Count(s => s.WeaknessPercent > 60);
        pomodoroCount = await Db.PomodoroSessions.CountAsync(p => p.UserId == uid && p.IsCompleted);
        consistencyPct = studyLogs.Any() ? (int)Math.Min(100, studyLogs.Average(l => l.HoursStudied) / 8 * 100) : 0;
        maxH = studyLogs.Any() ? studyLogs.Max(l => l.HoursStudied) : 10;

        // ✅ AI RECOMMENDATIONS: Rule-based smart suggestions
        var upcomingExams = await Db.Exams.Where(e => e.UserId == uid && e.ExamDate >= today).OrderBy(e => e.ExamDate).ToListAsync();
        var weakestSubject = dbSubjects.FirstOrDefault();

        if (weakestSubject != null && weakestSubject.WeaknessPercent > 65)
            recommendations.Add($"You are weak in {weakestSubject.Name} ({weakestSubject.WeaknessPercent}%). Study it today!");

        if (upcomingExams.Any())
        {
            var next = upcomingExams.First();
            int daysLeft = (int)(next.ExamDate - today).TotalDays;
            recommendations.Add($"{next.SubjectName} exam is in {daysLeft} day(s). Prioritize revision!");
        }

        if (studyLogs.Any() && studyLogs.Last().HoursStudied < 3)
            recommendations.Add("You studied less than 3 hours yesterday. Try to study more today.");

        if (tasksCompleted == 0)
            recommendations.Add("No tasks completed yet. Complete at least one task today!");

        if (consistencyPct >= 80)
            recommendations.Add("Excellent consistency! Keep it up.");
    }
}
