@namespace Smart_Study_Planner
@using Smart_Study_Planner.Services
@inject AuthService Auth

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Components.Layout.MainLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Components.Layout.MainLayout)">
            <p>Sorry, nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>
